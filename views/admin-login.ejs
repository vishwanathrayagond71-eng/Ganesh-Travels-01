<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<section class="auth-section">
  <div class="auth-bg" style="background-image: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1400')">
    <div class="auth-overlay"></div>
  </div>
  <div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
      <div class="col-md-4">
        <div class="auth-card">
          <div class="auth-logo">
            <i class="fas fa-shield-alt text-danger"></i>
            <h4>Admin Panel</h4>
          </div>
          <h3 class="auth-title">Admin Login</h3>
          <p class="auth-subtitle">Secure access for authorized administrators only</p>

          <% if (messages.error && messages.error.length > 0) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
          <% } %>

          <form action="/admin/login" method="POST">
            <div class="mb-3">
              <label class="form-label">Admin Email</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-envelope input-icon"></i>
                <input type="email" name="email" class="form-control ps-5" placeholder="admin@example.com" required>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Admin Password</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-lock input-icon"></i>
                <input type="password" name="password" id="adminPass" class="form-control ps-5" placeholder="••••••••" required>
                <button type="button" class="btn-eye" onclick="
                  const i = document.getElementById('adminPass');
                  const icon = this.querySelector('i');
                  if(i.type==='password'){i.type='text';icon.className='fas fa-eye-slash';}
                  else{i.type='password';icon.className='fas fa-eye';}"><i class="fas fa-eye"></i></button>
              </div>
            </div>
            <button type="submit" class="btn btn-danger w-100 btn-lg">
              <i class="fas fa-sign-in-alt me-2"></i>Admin Login
            </button>
          </form>

          <div class="auth-links mt-3">
            <a href="/login">← Back to User Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
