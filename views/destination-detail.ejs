<!-- Leaflet JavaScript library -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
  let map;
  let markers = {};
  const destLat = <%= destination.lat %>;
  const destLng = <%= destination.lng %>;
  const destName = "<%= destination.name %>";

  // Parse all nearby POIs passed from the server
  const nearbyPoisData = <%- JSON.stringify(nearbyPois) %>;

  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initialize Map layers (Street View and Google Satellite Hybrid)
    const streetMap = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap contributors'
    });

    const satelliteMap = L.tileLayer('https://mt1.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
      maxZoom: 20,
      attribution: '© Google Maps'
    });

    // Create Leaflet map centered at the destination
    map = L.map('detailMap', {
      zoomControl: false,
      layers: [streetMap]
    }).setView([destLat, destLng], 12);

    L.control.zoom({
      position: 'bottomright'
    }).addTo(map);

    // Layer selection control
    const baseMaps = {
      "🗺️ Street Map": streetMap,
      "🛰️ Satellite": satelliteMap
    };
    L.control.layers(baseMaps, null, { position: 'topright' }).addTo(map);

    // 2. Add Center Star Marker representing the Destination
    const starIcon = L.divIcon({
      html: `<div class="dest-star-pin" style="background: #ffd700; width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid #1d3557; box-shadow: 0 4px 10px rgba(0,0,0,0.4)">
              <i class="fas fa-star" style="color: #1d3557; font-size: 20px;"></i>
             </div>`,
      className: 'destination-center-pin',
      iconSize: [42, 42],
      iconAnchor: [21, 21]
    });

    L.marker([destLat, destLng], { icon: starIcon })
      .addTo(map)
      .bindPopup(`<h5>⭐ ${destName}</h5><p class="mb-0 text-muted" style="font-size:11px">Destination Center Point</p>`, { closeButton: false })
      .openPopup();

    // 3. Render markers for all nearby POIs
    plotNearbyPoiMarkers();
  });

  // Category Icon & Color Mapping for leaflet markers
  function getPoiStyle(category) {
    switch (category) {
      case 'temple':
        return { color: '#e9c46a', iconClass: 'fa-dharma-wheel' }; // Gold
      case 'tourist':
        return { color: '#1d3557', iconClass: 'fa-monument' }; // Dark Blue
      case 'restaurant':
        return { color: '#e63946', iconClass: 'fa-utensils' }; // Red
      case 'hotel':
      case 'lodge':
        return { color: '#2a9d8f', iconClass: 'fa-hotel' }; // Green
      case 'falls':
        return { color: '#00b4d8', iconClass: 'fa-water' }; // Light Blue
      default:
        return { color: '#9b5de5', iconClass: 'fa-map-pin' }; // Violet
    }
  }

  function plotNearbyPoiMarkers() {
    // Flatten nearbyPoisData categories into a single list
    const allPois = [];
    for (const category in nearbyPoisData) {
      allPois.push(...nearbyPoisData[category]);
    }

    allPois.forEach(poi => {
      const lat = parseFloat(poi.lat);
      const lng = parseFloat(poi.lng);
      if (isNaN(lat) || isNaN(lng)) return;

      const style = getPoiStyle(poi.category);

      // Custom marker icon
      const customHtmlIcon = L.divIcon({
        html: `<div style="background-color: ${style.color}; width: 32px; height: 32px; border-radius: 50% 50% 50% 0; transform: rotate(-45deg); display: flex; align-items: center; justify-content: center; border: 2px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3)">
                <i class="fas ${style.iconClass}" style="color: white; font-size: 13px; transform: rotate(45deg)"></i>
               </div>`,
        className: 'custom-map-pin',
        iconSize: [32, 32],
        iconAnchor: [16, 32]
      });

      // Assemble popup card content
      let stars = '';
      const r = Math.round(parseFloat(poi.rating) || 5);
      for (let i = 0; i < 5; i++) {
        stars += `<i class="fas fa-star ${i < r ? 'text-warning' : 'text-muted'}" style="font-size: 10px"></i>`;
      }

      const popupHtml = `
        <div class="map-popup-card">
          <img src="${poi.image || 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=300'}" class="map-popup-img" alt="${poi.name}">
          <div class="map-popup-body">
            <h6 class="map-popup-title">${poi.name}</h6>
            <div class="map-popup-meta">
              <span class="poi-badge badge-${poi.category}">${poi.category}</span>
              <div class="d-flex align-items-center gap-1">${stars}</div>
            </div>
            <p class="map-popup-desc" style="font-size: 0.72rem; line-height: 1.3;">${poi.description}</p>
            <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
              <span class="font-bold text-primary" style="font-size: 11px;">📍 ${poi.distance.toFixed(1)} km away</span>
              <a href="https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}" target="_blank" class="btn btn-primary btn-sm text-white px-2 py-0.5" style="font-size:10px;">
                <i class="fas fa-directions me-1"></i>Get Route
              </a>
            </div>
          </div>
        </div>
      `;

      // Plot marker
      const marker = L.marker([lat, lng], { icon: customHtmlIcon })
        .bindPopup(popupHtml, { closeButton: false });

      marker.addTo(map);
      markers[poi.id] = marker;
    });
  }

  // Click handler to zoom and focus on a specific POI marker from the tabbed list click
  function focusPoiOnMap(id, lat, lng) {
    if (markers[id]) {
      // Zoom and center the map on the POI
      map.setView([lat, lng], 15);
      markers[id].openPopup();
      
      // Smooth scroll back up to the map
      document.querySelector('.detail-map-wrapper').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>

