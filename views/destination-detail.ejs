<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Include Leaflet.js CDN -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

<style>
  /* Hero Parallax Header */
  .detail-hero {
    position: relative;
    height: 480px;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    display: flex;
    align-items: flex-end;
    color: white;
  }

  .detail-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.7) 100%);
    z-index: 1;
  }

  .detail-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 50px;
    width: 100%;
  }

  .dest-category-badge {
    background: var(--accent-color, #e63946);
    color: white;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    padding: 6px 16px;
    border-radius: 30px;
    letter-spacing: 1px;
    display: inline-block;
  }

  .dest-title {
    font-size: 3.5rem;
    font-weight: 800;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    margin: 10px 0;
  }

  .dest-meta-info {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    font-size: 1rem;
    font-weight: 600;
    align-items: center;
  }

  .dest-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .rating-stars {
    color: #ffc107;
  }

  /* Main section grid */
  .detail-container {
    padding: 60px 0;
    background: var(--bg-light, #f8f9fa);
  }

  .content-card {
    background: var(--bg-card, #ffffff);
    border: 1px solid var(--border-color, #e5e5e5);
    border-radius: var(--radius-md, 16px);
    padding: 30px;
    box-shadow: var(--shadow-sm, 0 2px 10px rgba(0,0,0,0.05));
    margin-bottom: 30px;
  }

  .content-card-title {
    font-weight: 700;
    color: var(--primary-color, #1d3557);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 2px solid var(--border-color, #e5e5e5);
    padding-bottom: 12px;
  }

  .description-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-dark, #333333);
  }

  /* Interactive Map styling */
  .detail-map-wrapper {
    height: 450px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color, #e5e5e5);
    position: relative;
    margin-top: 15px;
    box-shadow: var(--shadow-md, 0 4px 15px rgba(0,0,0,0.08));
  }

  #detailMap {
    width: 100%;
    height: 100%;
  }

  /* POIs Tabbed Section */
  .poi-tabs .nav-link {
    font-weight: 700;
    color: var(--text-dark);
    border: none;
    padding: 12px 20px;
    border-radius: 30px;
    margin-right: 8px;
    transition: var(--transition);
    background: transparent;
  }

  .poi-tabs .nav-link.active {
    background: var(--primary-color, #1d3557) !important;
    color: white !important;
    box-shadow: var(--shadow-sm);
  }

  .poi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
    margin-top: 20px;
  }

  @media(min-width: 992px) {
    .poi-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .poi-item-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm, 12px);
    overflow: hidden;
    display: flex;
    gap: 15px;
    padding: 15px;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    cursor: pointer;
  }

  .poi-item-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-light, #457b9d);
  }

  .poi-item-img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .poi-item-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .poi-item-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 4px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .poi-item-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-bottom: 6px;
  }

  .poi-badge {
    text-transform: capitalize;
    font-weight: 700;
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 12px;
  }

  .badge-temple { background: rgba(233, 196, 106, 0.2); color: #b58900; }
  .badge-tourist { background: rgba(29, 53, 87, 0.1); color: var(--primary-color); }
  .badge-restaurant { background: rgba(230, 57, 70, 0.1); color: var(--danger-color); }
  .badge-hotel, .badge-lodge { background: rgba(42, 157, 143, 0.1); color: var(--success-color); }
  .badge-falls { background: rgba(0, 180, 216, 0.1); color: #0077b6; }

  .poi-dist-badge {
    font-weight: 700;
    color: var(--primary-light);
  }

  .poi-item-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 10px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Booking Sidebar */
  .booking-sidebar-card {
    position: sticky;
    top: 90px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md, 16px);
    padding: 25px;
    box-shadow: var(--shadow-md);
  }

  .booking-sidebar-header {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 15px;
    margin-bottom: 20px;
  }

  .booking-sidebar-price {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--primary-color);
  }

  .booking-sidebar-price span {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* Custom Popup Map style */
  .leaflet-popup-content-wrapper {
    border-radius: var(--radius-md);
    padding: 0;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border-color);
  }

  .leaflet-popup-content {
    margin: 0;
    width: 250px !important;
  }

  .map-popup-card {
    font-family: var(--font-main);
  }

  .map-popup-img {
    width: 100%;
    height: 120px;
    object-fit: cover;
  }

  .map-popup-body {
    padding: 12px;
  }

  .map-popup-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0 0 6px 0;
    color: var(--text-dark);
  }

  .map-popup-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 10px 0;
    line-height: 1.4;
  }

  .map-popup-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    margin-bottom: 8px;
  }

  /* Custom Destination Star Pin */
  .dest-star-pin {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .empty-poi-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
  }

  .empty-poi-state i {
    font-size: 3rem;
    margin-bottom: 15px;
    color: var(--border-color);
  }

  /* Travel Guide Grid */
  .guide-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 15px;
  }
  @media(min-width: 576px) {
    .guide-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .guide-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .guide-icon {
    font-size: 1.3rem;
    color: var(--primary-color, #1d3557);
    background: rgba(29, 53, 87, 0.08);
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .guide-text h6 {
    font-weight: 700;
    margin: 0 0 4px 0;
    color: var(--text-dark, #1d3557);
    font-size: 0.95rem;
  }
  .guide-text p {
    font-size: 0.88rem;
    color: var(--text-muted, #555555);
    margin: 0;
    line-height: 1.5;
  }
  .safety-alert {
    background: rgba(230, 57, 70, 0.05);
    border-left: 4px solid var(--danger-color, #e63946);
    padding: 15px;
    border-radius: 4px 12px 12px 4px;
    margin-top: 20px;
  }
  .safety-title {
    font-weight: 700;
    color: var(--danger-color, #e63946);
    margin-bottom: 5px;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>

<!-- Page Hero Header -->
<div class="detail-hero" style="background-image: url('<%= destination.image %>')">
  <div class="detail-hero-overlay"></div>
  <div class="container">
    <div class="detail-hero-content">
      <span class="dest-category-badge mb-2"><i class="fas fa-tag me-1"></i><%= destination.category %></span>
      <h1 class="dest-title"><%= destination.name %></h1>
      <div class="dest-meta-info">
        <div class="dest-meta-item">
          <i class="fas fa-location-dot text-danger"></i>
          <span><%= destination.country %></span>
        </div>
        <div class="dest-meta-item">
          <div class="rating-stars">
            <% for(let i=0; i<5; i++) { %>
              <i class="fas fa-star <%= i < Math.round(destination.rating) ? '' : 'far text-muted' %>"></i>
            <% } %>
          </div>
          <span><%= destination.rating %> (<%= destination.reviews %> reviews)</span>
        </div>
        <div class="dest-meta-item">
          <i class="fas fa-tags text-warning"></i>
          <span>Starting from ₹<%= destination.price.toLocaleString() %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content Grid -->
<section class="detail-container">
  <div class="container">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
        <li class="breadcrumb-item"><a href="/destinations" class="text-decoration-none">Destinations</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= destination.name %></li>
      </ol>
    </nav>

    <!-- Flash message indicators -->
    <% if (messages.error) { %>
      <div class="alert alert-danger mb-4"><i class="fas fa-exclamation-circle me-2"></i><%= messages.error[0] %></div>
    <% } %>
    <% if (messages.success) { %>
      <div class="alert alert-success mb-4"><i class="fas fa-check-circle me-2"></i><%= messages.success[0] %></div>
    <% } %>

    <div class="row">
      <!-- Main Content (8 cols) -->
      <div class="col-lg-8">
        <!-- About Section -->
        <div class="content-card">
          <h4 class="content-card-title"><i class="fas fa-circle-info text-primary"></i>About this Destination</h4>
          <p class="description-text"><%= destination.description %></p>
          <p class="description-text text-muted mt-2">
            Experience the rich heritage, majestic history, local flavor, and exceptional atmosphere that defines this breathtaking spot. 
            Below, explore the local area guide including temples, waterfalls, hotels, and restaurants nearby.
          </p>
        </div>

        <%
          // Comprehensive Tourist Metadata Resolver
          const name = destination.name.toLowerCase();
          const c = destination.country.toLowerCase();
          const cat = destination.category.toLowerCase();

          // Basic variables
          let language = "English & Local Languages";
          let currency = "Local Currency";
          let emergency = "Tourist Helpdesk / Hotel Front Desk";
          let visaInfo = "Check local embassy guidelines. Ensure your passport is valid for at least 6 months.";

          if (c.includes("india")) {
            language = "Hindi, English, & Regional Languages";
            currency = "Indian Rupee (INR - ₹)";
            emergency = "📞 National Emergency Line: 112 | 📞 Tourist Helpline: 1363";
            visaInfo = "No visa required for Indian citizens. Certain regions (like Ladakh, Sikkim, or border areas) require Inner Line Permits (ILP) obtainable online.";
          } else if (c.includes("france")) {
            language = "French";
            currency = "Euro (EUR - €)";
            emergency = "📞 Emergency Services: 112";
            visaInfo = "Schengen Visa required for Indian passport holders. Apply in advance via VFS Global with proof of travel and insurance.";
          } else if (c.includes("uae") || c.includes("dubai")) {
            language = "Arabic & English";
            currency = "UAE Dirham (AED)";
            emergency = "📞 Police: 999 | 📞 Ambulance: 998 | 📞 Fire: 997";
            visaInfo = "Pre-arranged eVisa required for Indian nationals. Tourists holding valid US Visas or Green Cards can get a Visa on Arrival.";
          } else if (c.includes("singapore")) {
            language = "English, Mandarin, Malay, & Tamil";
            currency = "Singapore Dollar (SGD - S$)";
            emergency = "📞 Police: 999 | 📞 Ambulance: 995";
            visaInfo = "eVisa required for Indian nationals. Must be applied for via authorized agents or ICA portal prior to departure.";
          } else if (c.includes("japan") || name.includes("tokyo") || name.includes("kyoto")) {
            language = "Japanese";
            currency = "Japanese Yen (JPY - ¥)";
            emergency = "📞 Police: 110 | 📞 Fire & Ambulance: 119";
            visaInfo = "Short-term visa required. eVisa application is available online for Indian tourists through authorized travel agencies.";
          } else if (c.includes("thailand") || name.includes("bangkok") || name.includes("phuket")) {
            language = "Thai";
            currency = "Thai Baht (THB - ฿)";
            emergency = "📞 Tourist Police: 1155 | 📞 Ambulance: 1669";
            visaInfo = "Visa on Arrival (VoA) or eVisa available. Check latest notices as Thailand often extends temporary Visa-Free entry for Indians.";
          } else if (c.includes("maldives")) {
            language = "Dhivehi & English";
            currency = "Maldivian Rufiyaa (MVR) / US Dollar ($)";
            emergency = "📞 Police: 119 | 📞 Coast Guard: 191";
            visaInfo = "Free 30-day Visa on Arrival for all tourists, including Indians. Requires a valid passport, return ticket, and resort confirmation.";
          } else if (c.includes("united kingdom") || c.includes("uk") || name.includes("london")) {
            language = "English";
            currency = "British Pound (GBP - £)";
            emergency = "📞 Emergency Services: 999 / 112";
            visaInfo = "Standard Visitor Visa required in advance. Apply online, pay fees, and attend biometric collection at VFS centers.";
          } else if (c.includes("usa") || c.includes("united states") || name.includes("new york")) {
            language = "English";
            currency = "US Dollar (USD - $)";
            emergency = "📞 Emergency Services: 911";
            visaInfo = "B1/B2 Visitor Visa required. Requires application submission (DS-160), fee payment, and an in-person interview at US Consulate/Embassy.";
          } else if (c.includes("australia")) {
            language = "English";
            currency = "Australian Dollar (AUD - A$)";
            emergency = "📞 Emergency Services: 000";
            visaInfo = "Visitor Visa (Subclass 600) required. Apply online in advance; does not require physical passport submission in most cases.";
          } else if (c.includes("switzerland")) {
            language = "German, French, Italian, & Romansh";
            currency = "Swiss Franc (CHF)";
            emergency = "📞 Emergency: 112 | 📞 Police: 117 | 📞 Ambulance: 144";
            visaInfo = "Schengen Visa required. Application must be submitted at the Swiss Embassy/Consulate representative in India.";
          } else if (c.includes("italy")) {
            language = "Italian";
            currency = "Euro (EUR - €)";
            emergency = "📞 Emergency Services: 112";
            visaInfo = "Schengen Visa required. Apply via VFS Global in advance.";
          } else if (c.includes("greece")) {
            language = "Greek";
            currency = "Euro (EUR - €)";
            emergency = "📞 Emergency Services: 112 | 📞 Tourist Police: 171";
            visaInfo = "Schengen Visa required. Apply via Greece visa center in advance.";
          } else if (c.includes("iceland")) {
            language = "Icelandic";
            currency = "Icelandic Króna (ISK)";
            emergency = "📞 Emergency Services: 112";
            visaInfo = "Schengen Visa required. Managed by Denmark visa processing center in India.";
          } else if (c.includes("canada")) {
            language = "English & French";
            currency = "Canadian Dollar (CAD - C$)";
            emergency = "📞 Emergency Services: 911";
            visaInfo = "Temporary Resident Visa (TRV) required. Apply online in advance and submit biometrics.";
          } else if (c.includes("malaysia")) {
            language = "Malay (Bahasa Melayu) & English";
            currency = "Malaysian Ringgit (MYR - RM)";
            emergency = "📞 Emergency Line: 999 | 📞 Tourist Police: 03-21496590";
            visaInfo = "eVisa (eNTRI or Tourist) required. Keep digital/printed copies of visa approvals, return tickets, and lodging proof.";
          } else if (c.includes("peru")) {
            language = "Spanish & Quechua";
            currency = "Peruvian Sol (PEN)";
            emergency = "📞 Police: 105 | 📞 Tourist Police: 01-4601060";
            visaInfo = "Visa required. However, Indian passport holders with valid US, UK, Canada, Australia, or Schengen visas (valid for min 6 months) get visa-free entry for up to 180 days.";
          } else if (c.includes("jordan")) {
            language = "Arabic";
            currency = "Jordanian Dinar (JOD)";
            emergency = "📞 Police & Emergency: 911";
            visaInfo = "Visa on Arrival is available for Indian passport holders (approx. 40 JOD). Alternatively, purchasing the Jordan Pass online waives visa fees.";
          } else if (c.includes("egypt")) {
            language = "Arabic";
            currency = "Egyptian Pound (EGP)";
            emergency = "📞 Tourist Police: 126 | 📞 Ambulance: 123";
            visaInfo = "eVisa or Visa on Arrival is available for Indian citizens holding valid Schengen, US, UK, or Canadian visas. Otherwise, apply in advance.";
          } else if (c.includes("south africa")) {
            language = "English & 10 other official languages";
            currency = "South African Rand (ZAR - R)";
            emergency = "📞 Police: 10111 | 📞 Ambulance: 10177";
            visaInfo = "Visa required in advance. eVisa portal is open for Indian tourists, or applications can be processed via VFS Global.";
          } else if (c.includes("brazil")) {
            language = "Portuguese";
            currency = "Brazilian Real (BRL - R$)";
            emergency = "📞 Police: 190 | 📞 Ambulance: 192";
            visaInfo = "Visa required in advance for Indian citizens. Apply online at the consular portal and submit documents at the Embassy center.";
          } else if (c.includes("turkey")) {
            language = "Turkish";
            currency = "Turkish Lira (TRY - ₺)";
            emergency = "📞 Emergency Line: 112 (All services)";
            visaInfo = "Regular visa required in advance. Indian passport holders with valid US, UK, or Schengen visas can apply for an eVisa online.";
          } else if (c.includes("spain")) {
            language = "Spanish";
            currency = "Euro (EUR - €)";
            emergency = "📞 Emergency Services: 112";
            visaInfo = "Schengen Visa required. Apply via BLS International center in advance.";
          } else if (c.includes("netherlands")) {
            language = "Dutch";
            currency = "Euro (EUR - €)";
            emergency = "📞 Emergency Services: 112";
            visaInfo = "Schengen Visa required. Apply via VFS Global in advance.";
          } else if (c.includes("cambodia")) {
            language = "Khmer";
            currency = "Cambodian Riel (KHR) / US Dollar ($)";
            emergency = "📞 Tourist Police: 117 | 📞 Ambulance: 119";
            visaInfo = "Visa on Arrival (VoA) or eVisa is available for Indian passport holders. Visa fee is around $30-$36.";
          } else if (c.includes("south korea")) {
            language = "Korean";
            currency = "South Korean Won (KRW - ₩)";
            emergency = "📞 Police: 112 | 📞 Fire & Ambulance: 119 | 📞 Tourist Helpline: 1330";
            visaInfo = "Regular Tourist Visa required in advance for Indian passport holders. Apply via designated application centers.";
          } else if (c.includes("new zealand")) {
            language = "English & Maori";
            currency = "New Zealand Dollar (NZD - NZ$)";
            emergency = "📞 Emergency Services: 111";
            visaInfo = "Visitor Visa required. Apply online via Immigration New Zealand. Usually takes 3-4 weeks to process.";
          }

          // --- HOW TO REACH (LOGISTICS) RESOLUTION ---
          let nearestAir = "International Airport";
          let nearestRail = "Major Railway Station";
          let nearestRoad = "National Highways & City Bus Terminals";
          let localTransit = "Local Taxi Services, Buses, and Auto-rickshaws";

          if (name.includes("varanasi")) {
            nearestAir = "Lal Bahadur Shastri International Airport (VNS) - 24 km from city center. Regular flights from Delhi, Mumbai, Bengaluru.";
            nearestRail = "Varanasi Junction (BSB) or Pt. Deen Dayal Upadhyaya Junction (DDU) - connects to major Indian cities.";
            nearestRoad = "NH2 connects Varanasi to Kolkata and Delhi. Inter-state bus services arrive at Chaudhary Charan Singh Bus Terminus.";
            localTransit = "Cycle rickshaws and auto-rickshaws dominate the old streets. App cabs (Ola/Uber) and e-rickshaws are available in newer parts.";
          } else if (name.includes("goa")) {
            nearestAir = "Manohar International Airport (Mopa - GOX) or Dabolim Airport (GOI) - daily flights from all Indian hubs.";
            nearestRail = "Madgaon (MAO) or Thivim (THVM) Railway Station - connected via Konkan Railway.";
            nearestRoad = "NH66 connects Goa to Mumbai and Mangalore. Kadamba Transport Corporation (KTC) runs regular AC/non-AC buses.";
            localTransit = "Self-drive scooter/car rentals are highly popular. Pilot motorbikes (unique bike taxi) and tourist taxis (GoaMiles app) are available.";
          } else if (name.includes("manali")) {
            nearestAir = "Kullu-Manali Airport (Bhuntar - KUU) - 50 km away. Alternatively, Chandigarh International Airport (IXC) - 250 km away (preferred for flight frequency).";
            nearestRail = "Joginder Nagar Railway Station (narrow gauge) - 144 km away. Or Ambala Cantt / Chandigarh Junction (broad gauge) - 300 km away.";
            nearestRoad = "NH21 connects Chandigarh to Manali. Overnight luxury Volvo sleeper buses run daily from Delhi and Chandigarh.";
            localTransit = "Local auto-rickshaws, private cabs, and motorcycle rentals (Royal Enfields are popular for Rohtang/Solang transit).";
          } else if (name.includes("ladakh")) {
            nearestAir = "Kushok Bakula Rimpochee Airport (IXL) in Leh - flights from Delhi, Srinagar, and Jammu. Flight bookings should be made early.";
            nearestRail = "Jammu Tawi Railway Station - 700 km away (not recommended for direct access).";
            nearestRoad = "Srinagar-Leh Highway (NH1D) or Manali-Leh Highway - open seasonal (May to October). Scenic but requires acclimatization.";
            localTransit = "Shared tourist taxis (SUV/Tempo Travelers) are standard. Bullet motorbikes are widely rented for Pangong/Nubra road trips.";
