              budgetMidrange = "₹5,000 - ₹10,000 / day (Private villas, seafood dinners, hired drivers)";
              budgetLuxury = "₹15,000 - ₹30,000+ / day (5-star luxury beachfront resorts, private speedboats)";
              bProgress = [15, 45, 80];
