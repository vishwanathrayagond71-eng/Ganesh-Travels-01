<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Flash Messages -->
<% if (messages.success && messages.success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
    <i class="fas fa-check-circle me-2"></i><%= messages.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (messages.error && messages.error.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i><%= messages.error[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- ============================================================
     HERO SECTION - Full-screen image slider with search
     ============================================================ -->
<section class="hero-section" id="hero">
  <div class="hero-slider" id="heroSlider">
    <div class="hero-slide active" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600')">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-badge"><i class="fas fa-star me-1"></i>Trusted by 50,000+ Travelers</div>
        <h1 class="hero-title">Discover the <span class="hero-highlight">Wonders</span> of India</h1>
        <p class="hero-subtitle">From the mighty Himalayas to the serene backwaters — your perfect journey starts here</p>
      </div>
    </div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=1600')">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-badge"><i class="fas fa-map-location-dot me-1"></i>770+ Indian Districts Covered</div>
        <h1 class="hero-title">Explore the <span class="hero-highlight">Beauty</span> of India</h1>
        <p class="hero-subtitle">Unforgettable domestic tours at the best prices — discover your homeland with us</p>
      </div>
    </div>
    <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1600')">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-badge"><i class="fas fa-heart me-1"></i>Honeymoon Specialists</div>
        <h1 class="hero-title">Your Dream <span class="hero-highlight">Honeymoon</span> Awaits</h1>
        <p class="hero-subtitle">Romantic packages crafted for couples — creating memories that last a lifetime</p>
      </div>
    </div>
  </div>

  <!-- Slider Controls -->
  <button class="hero-prev" onclick="changeSlide(-1)"><i class="fas fa-chevron-left"></i></button>
  <button class="hero-next" onclick="changeSlide(1)"><i class="fas fa-chevron-right"></i></button>
  <div class="hero-dots" id="heroDots">
    <span class="hero-dot active" onclick="goToSlide(0)"></span>
    <span class="hero-dot" onclick="goToSlide(1)"></span>
    <span class="hero-dot" onclick="goToSlide(2)"></span>
  </div>

  <!-- Search Bar -->
  <div class="hero-search-wrapper">
    <div class="hero-search-box">
      <h5 class="text-center mb-3"><i class="fas fa-search me-2"></i>Find Your Perfect Destination</h5>
      <form action="/destinations" method="GET" class="hero-search-form">
        <div class="row g-2">
          <div class="col-md-5">
            <input type="text" name="q" class="form-control form-control-lg" placeholder="🌍 Where do you want to go?">
          </div>
          <div class="col-md-3">
            <input type="date" name="date" class="form-control form-control-lg">
          </div>
          <div class="col-md-2">
            <select name="guests" class="form-control form-control-lg">
              <option value="">Guests</option>
              <option>1 Person</option>
              <option>2 People</option>
              <option>3-5 People</option>
              <option>6+ People</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-lg w-100">Search</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- ============================================================
     STATS SECTION
     ============================================================ -->
<section class="stats-section">
  <div class="container">
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <i class="fas fa-users"></i>
          <h3 class="counter" data-target="50000">0</h3>
          <p>Happy Travelers</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <i class="fas fa-map-marked-alt"></i>
          <h3 class="counter" data-target="200">0</h3>
          <p>Destinations</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <i class="fas fa-trophy"></i>
          <h3 class="counter" data-target="15">0</h3>
          <p>Years Experience</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <i class="fas fa-star"></i>
          <h3>4.9</h3>
          <p>Average Rating</p>
        </div>
      </div>
    </div>
  </div>
</section>

