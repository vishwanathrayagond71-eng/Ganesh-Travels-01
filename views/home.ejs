<!-- ============================================================
     FEATURED DESTINATIONS
     ============================================================ -->
<section class="section-padding bg-light-custom">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Popular Picks</span>
      <h2>Featured Destinations</h2>
      <p>Handpicked destinations that our travelers love most</p>
    </div>
    <div class="row g-4">
      <% destinations.forEach(dest => { %>
      <div class="col-md-6 col-lg-4">
        <div class="destination-card">
          <div class="destination-img-wrapper">
            <img src="<%= dest.image %>" alt="<%= dest.name %>" class="destination-img" loading="lazy">
            <div class="destination-badge"><%= dest.country %></div>
            <button class="wishlist-btn" onclick="toggleWishlist(this, '<%= dest.id %>', '<%= dest.name %>')" title="Add to Wishlist">
              <i class="far fa-heart"></i>
            </button>
            <div class="destination-overlay">
              <a href="/booking?destination=<%= dest.name %>" class="btn btn-light btn-sm">Book Now</a>
            </div>
          </div>
          <div class="destination-info">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <h6 class="destination-name"><%= dest.name %></h6>
              <span class="price-badge">₹<%= dest.price.toLocaleString() %></span>
            </div>
            <div class="rating-row mb-2">
              <% for(let i=0; i<5; i++) { %>
                <i class="fas fa-star <%= i < Math.round(dest.rating) ? 'text-warning' : 'text-muted' %>"></i>
              <% } %>
              <span class="rating-count">(<%= dest.reviews %>)</span>
            </div>
            <p class="destination-desc"><%= dest.description.substring(0, 80) %>...</p>
            <a href="/booking?destination=<%= dest.name %>" class="btn btn-primary btn-sm w-100 mt-2">
              <i class="fas fa-calendar-check me-1"></i>Book Now
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-4">
      <a href="/destinations" class="btn btn-outline-primary btn-lg">
        View All Destinations <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     POPULAR PACKAGES
     ============================================================ -->
<section class="section-padding">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Best Value</span>
      <h2>Popular Tour Packages</h2>
      <p>All-inclusive packages curated for the best travel experience</p>
    </div>
    <div class="row g-4">
      <% packages.forEach(pkg => { %>
      <div class="col-md-6 col-lg-4">
        <div class="package-card">
          <div class="package-img-wrapper">
            <img src="<%= pkg.image %>" alt="<%= pkg.name %>" loading="lazy">
            <div class="package-type-badge"><%= pkg.type.charAt(0).toUpperCase() + pkg.type.slice(1) %></div>
          </div>
          <div class="package-info">
            <h5><%= pkg.name %></h5>
            <p class="package-destinations"><i class="fas fa-route me-1"></i><%= pkg.destinations %></p>
            <div class="package-meta">
              <span><i class="fas fa-clock me-1"></i><%= pkg.duration %></span>
              <span class="package-price">₹<%= pkg.price.toLocaleString() %></span>
            </div>
            <ul class="package-services">
              <% pkg.services.slice(0,3).forEach(s => { %>
                <li><i class="fas fa-check-circle text-success me-1"></i><%= s %></li>
              <% }) %>
            </ul>
            <a href="/booking?destination=<%= pkg.name %>" class="btn btn-primary w-100 mt-2">
              <i class="fas fa-paper-plane me-1"></i>Book This Package
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-4">
      <a href="/packages" class="btn btn-outline-primary btn-lg">
        Explore All Packages <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>
  </div>
</section>

